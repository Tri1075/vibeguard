{
  "schemaVersion": 1,
  "profile": "experienced",
  "ignore": [
    "*.min.js",
    "*.lock",
    "vendor/**"
  ],
  "rules": {
    "plan-first": {
      "enabled": true,
      "severity": "warn",
      "params": {
        "minSections": 3,
        "minLines": 15
      },
      "ignore": []
    },
    "robust-stack": {
      "enabled": true,
      "severity": "warn",
      "params": {},
      "ignore": []
    },
    "modules-small": {
      "enabled": true,
      "severity": "block",
      "params": {
        "maxLines": 200,
        "warnAt": 160
      },
      "ignore": []
    },
    "no-tech-debt": {
      "enabled": true,
      "severity": "block",
      "params": {
        "markers": [
          "TODO",
          "FIXME",
          "HACK",
          "XXX"
        ]
      },
      "ignore": []
    },
    "deps-hygiene": {
      "enabled": true,
      "severity": "block",
      "params": {},
      "ignore": []
    },
    "no-secrets": {
      "enabled": true,
      "severity": "block",
      "params": {},
      "ignore": [
        "src/gates/no-secrets.ts",
        "src/gates/secure-code.ts",
        "test/**"
      ]
    },
    "secure-code": {
      "enabled": true,
      "severity": "block",
      "params": {},
      "ignore": [
        "src/gates/secure-code.ts",
        "src/gates/no-secrets.ts",
        "test/**"
      ]
    },
    "no-dead-code": {
      "enabled": true,
      "severity": "warn",
      "params": {},
      "ignore": [
        "test/**"
      ]
    },
    "error-handling": {
      "enabled": true,
      "severity": "block",
      "params": {},
      "ignore": [
        "test/**"
      ]
    }
  }
}
